Options -Indexes
RewriteEngine On

# Eski .html URL'lerini yeni statik rota yapısına tek adımda taşı.
RewriteRule ^index\.html$ https://www.etayangin.com.tr/ [R=301,L,NE]
RewriteRule ^hakkimizda\.html$ https://www.etayangin.com.tr/hakkimizda/ [R=301,L,NE]
RewriteRule ^urunlerimiz\.html$ https://www.etayangin.com.tr/urunlerimiz/ [R=301,L,NE]
RewriteRule ^referanslar\.html$ https://www.etayangin.com.tr/referanslarimiz/ [R=301,L,NE]
RewriteRule ^referanslarimiz\.html$ https://www.etayangin.com.tr/referanslarimiz/ [R=301,L,NE]
RewriteRule ^iletisim\.html$ https://www.etayangin.com.tr/iletisim/ [R=301,L,NE]
RewriteRule ^yangin-sondurme-cihazlari\.html$ https://www.etayangin.com.tr/yangin-sondurme-cihazlari/ [R=301,L,NE]
RewriteRule ^yangin-sondurme-sistemleri\.html$ https://www.etayangin.com.tr/yangin-sondurme-sistemleri/ [R=301,L,NE]
RewriteRule ^yangin-dolaplari-ve-hidrantlari\.html$ https://www.etayangin.com.tr/yangin-dolaplari-ve-hidrantlari/ [R=301,L,NE]
RewriteRule ^yangin-dolaplari-ve-hidrantlar\.html$ https://www.etayangin.com.tr/yangin-dolaplari-ve-hidrantlari/ [R=301,L,NE]
RewriteRule ^yangin-algilama-ve-ihbar-sistemleri\.html$ https://www.etayangin.com.tr/yangin-algilama-ihbar-sistemleri/ [R=301,L,NE]
RewriteRule ^yangin-algilama-ihbar-sistemleri\.html$ https://www.etayangin.com.tr/yangin-algilama-ihbar-sistemleri/ [R=301,L,NE]
RewriteRule ^itfaiye-malzemeleri\.html$ https://www.etayangin.com.tr/itfaiye-malzemeleri/ [R=301,L,NE]
RewriteRule ^arama-ve-kurtarma-malzemeleri\.html$ https://www.etayangin.com.tr/arama-kurtarma-malzemeleri/ [R=301,L,NE]
RewriteRule ^arama-kurtarma-malzemeleri\.html$ https://www.etayangin.com.tr/arama-kurtarma-malzemeleri/ [R=301,L,NE]
RewriteRule ^yangin-kapisi-ve-merdivenleri\.html$ https://www.etayangin.com.tr/yangin-kapisi-ve-merdivenleri/ [R=301,L,NE]
RewriteRule ^acil-aydinlatma-ve-yonlendirme\.html$ https://www.etayangin.com.tr/acil-aydinlatma-yonlendirme/ [R=301,L,NE]
RewriteRule ^acil-aydinlatma-yonlendirme\.html$ https://www.etayangin.com.tr/acil-aydinlatma-yonlendirme/ [R=301,L,NE]
RewriteRule ^is-guvenligi\.html$ https://www.etayangin.com.tr/is-guvenligi/ [R=301,L,NE]

# Kalan eski .html sayfaları aynı slug varsa temiz URL'ye taşınır.
RewriteRule ^(.+)\.html$ https://www.etayangin.com.tr/$1/ [R=301,L,NE]

# Tek canonical host: HTTPS + www.etayangin.com.tr
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.etayangin\.com\.tr$ [NC]
RewriteRule ^(.*)$ https://www.etayangin.com.tr/$1 [R=301,L,NE]

# 404 sayfası
ErrorDocument 404 /404.html

# Güvenlik: gizli dosyalara erişimi engelle
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

# Önbellekleme (performans)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Gzip sıkıştırma (performans)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
